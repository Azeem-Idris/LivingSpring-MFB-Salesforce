<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Age_Restriction</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT(ISBLANK( Birth_Date__c )),
   Birth_Date__c  &gt; ADDMONTHS(TODAY(), -18 * 12)
)</errorConditionFormula>
    <errorDisplayField>Birth_Date__c</errorDisplayField>
    <errorMessage>Customer must be at least 18 years old to borrow.</errorMessage>
</ValidationRule>
